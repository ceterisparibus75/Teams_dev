# ─── Base de données ──────────────────────────────────────────────────────────
# URL avec connection pooler (Supabase, Neon…) — utilisée par Next.js (serverless)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
# URL directe (sans pooler) — utilisée uniquement par les migrations Prisma
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Azure AD (Entra ID) ──────────────────────────────────────────────────────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ─── IA ───────────────────────────────────────────────────────────────────────
# Claude Opus — génération des procès-verbaux
ANTHROPIC_API_KEY=""
# OpenAI Whisper — transcription audio (bot navigateur uniquement)
OPENAI_API_KEY=""

# ─── Observabilité (optionnel) ───────────────────────────────────────────────
# Si défini, les logs niveau error sont envoyés à Sentry automatiquement.
# Format : https://<key>@oXXXXXX.ingest.sentry.io/<project>
# SENTRY_DSN=""
# Niveau de log (trace / debug / info / warn / error / fatal)
# LOG_LEVEL="info"

# ─── Inngest (job queue durable pour la génération PV) ───────────────────────
# Vide en local : Inngest tourne via `npx inngest-cli@latest dev` (dashboard 8288)
# Prod : récupérer les clés sur app.inngest.com (ou via l'intégration Vercel)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Sécurité endpoints ───────────────────────────────────────────────────────
# Token Bearer pour /api/cron/poll (générer avec : openssl rand -base64 32)
CRON_SECRET="generate-with-openssl-rand-base64-32"
# Secret header bot → /api/bot-generate/ (générer avec : openssl rand -base64 32)
BOT_SECRET="generate-with-openssl-rand-base64-32"

# ─── Service bot (optionnel — uniquement si bot navigateur déployé) ───────────
# URL de l'app Next.js accessible depuis le service bot
APP_URL="http://localhost:3000"
# Port Express du bot (défaut : 3001)
# BOT_PORT=3001
# Display Xvfb Linux (défaut : :99) — Linux uniquement
# BOT_DISPLAY=:99
# Dossier audio temporaire (défaut : /tmp/bot-audio)
# BOT_AUDIO_DIR=/tmp/bot-audio
